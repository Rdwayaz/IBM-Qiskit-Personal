def run_quantum_vqe_real_hardware(hamiltonian, warm_params):
    section("④ QUANTUM VQE — Real IBM Quantum Hardware")
    print(f"  │   Connecting to IBM Quantum platform...")

    try:
        service = QiskitRuntimeService(
            channel="ibm_quantum_platform",
            token=IBM_TOKEN
        )
        backend = service.least_busy(operational=True, simulator=False)
        print(f"  │   ✅ Connected to: {backend.name}")
        print(f"  │   Qubits available: {backend.num_qubits}")
        divider()
    except Exception as e:
        print(f"  │   ❌ Could not connect: {e}")
        endsection()
        return None, None, []

    energy_log = []
    iteration  = [0]

    with Session(backend=backend) as session:
        estimator = Estimator(session=session)

        def energy_fn(params):
            qc   = build_ansatz(params)
            qc_t = transpile(qc, backend, optimization_level=3)  # highest opt for real hw
            pub  = (qc_t, hamiltonian)
            job  = estimator.run([pub])
            energy = job.result()[0].data.evs.item()
            energy_log.append(energy)
            iteration[0] += 1
            print(f"  │   Step {iteration[0]:>3}: energy = {energy:.6f} Ha  [real quantum chip]")
            return energy

        print(f"  │   Warm start energy: {energy_fn(warm_params):.6f} Ha")
        divider()

        t0 = time.time()
        result = minimize(
            energy_fn,
            warm_params,
            method="COBYLA",
            options={"maxiter": 20, "rhobeg": 0.1}   # fewer iterations on real hw (costs quota)
        )
        hw_time = time.time() - t0

    final_energy = result.fun
    error        = abs(final_energy - EXACT_GROUND_STATE_ENERGY)

    divider()
    result_row("Ground state energy",  f"{final_energy:.6f}", " Ha", highlight=True)
    result_row("Known exact value",    f"{EXACT_GROUND_STATE_ENERGY:.6f}", " Ha")
    result_row("Error (real hw noise)",f"{error:.6f}", " Ha")
    result_row("VQE iterations",       f"{iteration[0]}")
    result_row("Time (inc. queue)",    f"{hw_time:.1f}", " s")
    endsection()

    return final_energy, hw_time, energy_log


# ─────────────────────────────────────────────────────────
#  CONVERGENCE CHART (ASCII)
# ─────────────────────────────────────────────────────────

def print_convergence_chart(classical_log, sim_log, hw_log=None):
    banner("📈  CONVERGENCE CHART\n   Energy vs VQE Iteration")

    all_logs = [("Classical VQE", classical_log, "▲"),
                ("Noisy Sim VQE", sim_log,       "●")]
    if hw_log:
        all_logs.append(("Real HW VQE", hw_log, "◆"))

    chart_height = 10
    chart_width  = 50
    target       = EXACT_GROUND_STATE_ENERGY

    for label, log, marker in all_logs:
        if not log:
            continue
        # Downsample to chart_width points
        step = max(1, len(log) // chart_width)
        samples = log[::step][:chart_width]

        min_e = min(samples + [target]) - 0.05
        max_e = max(samples) + 0.05

        print(f"\n  {label}  (target = {target:.4f} Ha)")
        print(f"  {'─'*chart_width}")

        for row in range(chart_height, -1, -1):
            threshold = min_e + (max_e - min_e) * row / chart_height
            if row == chart_height or row == 0:
                y_label = f"{threshold:>7.4f} |"
            elif abs(threshold - target) < (max_e - min_e) / chart_height:
                y_label = f"  exact ┤"   # mark exact line
            else:
                y_label = f"        |"

            line = ""
            for i, e in enumerate(samples):
                if abs(e - threshold) < (max_e - min_e) / chart_height:
                    line += marker
                else:
                    line += " "
            print(f"  {y_label}{line}")

        print(f"  {'':>8} └{'─'*chart_width}")
        print(f"  {'':>9}  iteration →")


