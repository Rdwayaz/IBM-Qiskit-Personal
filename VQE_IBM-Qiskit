# ─────────────────────────────────────────────────────────
#  THE H₂ HAMILTONIAN
#
#  The H₂ molecule's energy operator written as a sum of
#  Pauli matrices (the language quantum computers speak).
#  These coefficients come from quantum chemistry calculations
#  at equilibrium bond length (0.735 Å) in STO-3G basis.
#
#  H = g₀·II + g₁·ZI + g₂·IZ + g₃·ZZ + g₄·XX + g₅·YY
#
#  Exact ground state energy: -1.8572 Hartree
#  (1 Hartree = 27.211 eV = enough energy to ionise hydrogen)
# ─────────────────────────────────────────────────────────

H2_PAULI_TERMS = [
    ("II", -1.0523732),
    ("ZI",  0.3979374),
    ("IZ", -0.3979374),
    ("ZZ", -0.0112801),
    ("XX",  0.1809312),
    ("YY",  0.1809312),
]
EXACT_GROUND_STATE_ENERGY = -1.8572   # Hartree (known from quantum chemistry)
MOLECULE_NAME = "H₂ (Hydrogen molecule)"


