# ─────────────────────────────────────────────────────────
#  BUILD THE HAMILTONIAN
# ─────────────────────────────────────────────────────────

def build_hamiltonian():
    """Build the H₂ Hamiltonian as a SparsePauliOp (Qiskit format)
    and as a dense numpy matrix (for classical exact diagonalisation)."""

    pauli_list = [(term, coeff) for term, coeff in H2_PAULI_TERMS]
    hamiltonian = SparsePauliOp.from_list(pauli_list)

    # Also build the 4×4 matrix for classical exact solving
    # Pauli matrices
    I  = np.eye(2)
    X  = np.array([[0, 1], [1, 0]])
    Y  = np.array([[0, -1j], [1j, 0]])
    Z  = np.array([[1, 0], [0, -1]])
    paulis = {"I": I, "X": X, "Y": Y, "Z": Z}

    matrix = np.zeros((4, 4), dtype=complex)
    for term, coeff in H2_PAULI_TERMS:
        p1, p2 = paulis[term[0]], paulis[term[1]]
        matrix += coeff * np.kron(p1, p2)

    return hamiltonian, matrix


# ─────────────────────────────────────────────────────────
#  THE ANSATZ CIRCUIT
#
#  An "ansatz" is a quantum circuit with tunable angles (θ).
#  VQE searches for the angles that minimise the energy.
#  This is the Ry-CNOT hardware-efficient ansatz —
#  simple enough to run on today's noisy quantum chips.
#
#  Circuit diagram:
#  q0: ─[Ry(θ₀)]──●──[Ry(θ₂)]─
#                  │
#  q1: ─[Ry(θ₁)]──⊕──[Ry(θ₃)]─
# ─────────────────────────────────────────────────────────

def build_ansatz(params):
    """Build a 2-qubit variational circuit with 4 parameters."""
    qc = QuantumCircuit(2)
    qc.ry(params[0], 0)
    qc.ry(params[1], 1)
    qc.cx(0, 1)            # CNOT — creates entanglement between qubits
    qc.ry(params[2], 0)
    qc.ry(params[3], 1)
    return qc


# ─────────────────────────────────────────────────────────
#  ① CLASSICAL EXACT SOLUTION
#  Diagonalise the Hamiltonian matrix to find exact energies.
#  This is the "gold standard" — but scales exponentially.
# ─────────────────────────────────────────────────────────

def run_classical_exact(matrix):
    section("① CLASSICAL — Exact Diagonalisation")
    print(f"  │   Method : numpy linear algebra (eigh)")
    print(f"  │   Molecule: {MOLECULE_NAME}")
    print(f"  │   Matrix  : 4×4 (2 qubits = 2² states)")
    divider()

    t0 = time.time()
    eigenvalues, eigenvectors = eigh(matrix)   # find ALL energy levels
    classical_time = time.time() - t0

    ground_state_energy  = eigenvalues[0].real
    excited_state_energy = eigenvalues[1].real
    energy_gap           = excited_state_energy - ground_state_energy
    error                = abs(ground_state_energy - EXACT_GROUND_STATE_ENERGY)

    print(f"  │   All energy levels found:")
    for i, e in enumerate(eigenvalues):
        label = "← ground state" if i == 0 else f"excited state {i}"
        print(f"  │     E{i} = {e.real:>10.6f} Ha   {label}")

    divider()
    result_row("Ground state energy",  f"{ground_state_energy:.6f}", " Ha", highlight=True)
    result_row("Known exact value",    f"{EXACT_GROUND_STATE_ENERGY:.6f}", " Ha")
    result_row("Error",                f"{error:.2e}", " Ha")
    result_row("Energy gap (E1-E0)",   f"{energy_gap:.6f}", " Ha")
    result_row("Time",                 f"{classical_time*1000:.3f}", " ms")
    endsection()

    print(f"""
  ℹ️  Why this gets impossible fast:
     H₂  (2 electrons)  →   4×4 matrix  ✅ trivial
     H₂O (10 electrons) →  1024×1024    ✅ manageable
     Caffeine (102 e⁻)  →  2^102 × 2^102  ❌ more entries
                            than atoms in the universe
    """)

    return ground_state_energy, classical_time


# ─────────────────────────────────────────────────────────
#  ② CLASSICAL VQE SIMULATION
#  Run VQE but cheat — use statevector maths instead of
#  a real quantum chip. Same algorithm, no quantum noise.
# ─────────────────────────────────────────────────────────

def run_classical_vqe(hamiltonian):
    section("② CLASSICAL VQE SIMULATION (statevector)")
    print(f"  │   Method : VQE with exact statevector backend")
    print(f"  │   Ansatz : Ry-CNOT-Ry (4 parameters)")
    print(f"  │   Optimiser: COBYLA (gradient-free)")
    divider()

    estimator   = StatevectorEstimator()
    energy_log  = []
    iteration   = [0]

    def energy_fn(params):
        """Compute ⟨ψ(θ)|H|ψ(θ)⟩ — the expected energy for these angles."""
        qc  = build_ansatz(params)
        pub = (qc, hamiltonian)
        job = estimator.run([pub])
        energy = job.result()[0].data.evs.item()
        energy_log.append(energy)
        iteration[0] += 1
        if iteration[0] % 10 == 0:
            print(f"  │   Step {iteration[0]:>3}: energy = {energy:.6f} Ha")
        return energy

    # Random starting angles
    np.random.seed(42)
    init_params = np.random.uniform(0, 2*np.pi, 4)
    print(f"  │   Starting energy: {energy_fn(init_params):.6f} Ha")
    divider()

    t0 = time.time()
    result = minimize(
        energy_fn,
        init_params,
        method="COBYLA",
        options={"maxiter": MAX_ITERATIONS, "rhobeg": 0.5}
    )
    vqe_time = time.time() - t0

    final_energy = result.fun
    error        = abs(final_energy - EXACT_GROUND_STATE_ENERGY)

    divider()
    result_row("Ground state energy",  f"{final_energy:.6f}", " Ha", highlight=True)
    result_row("Known exact value",    f"{EXACT_GROUND_STATE_ENERGY:.6f}", " Ha")
    result_row("Error",                f"{error:.6f}", " Ha")
    result_row("VQE iterations",       f"{iteration[0]}")
    result_row("Converged",            "Yes" if result.success else "Partial")
    result_row("Time",                 f"{vqe_time:.3f}", " s")
    endsection()

    return final_energy, vqe_time, result.x, energy_log   # return best params


# ─────────────────────────────────────────────────────────
#  ③ QUANTUM VQE — SIMULATOR (FakeManilaV2)
#  Same VQE, but now circuits run on a fake quantum chip
#  that models REAL noise, gate errors, and decoherence.
# ─────────────────────────────────────────────────────────

def run_quantum_vqe_simulator(hamiltonian, warm_params):
    section("③ QUANTUM VQE — Noisy Simulator (FakeManilaV2)")
    print(f"  │   Backend: FakeManilaV2 (IBM Manila noise model)")
    print(f"  │   Shots  : 1024 per energy evaluation")
    print(f"  │   Note   : Includes real gate errors & decoherence")
    print(f"  │   Warm start: using best params from step ②")
    divider()

    backend   = FakeManilaV2()
    estimator = Estimator(backend)
    energy_log = []
    iteration  = [0]

    def energy_fn(params):
        qc  = build_ansatz(params)
        qc_t = transpile(qc, backend, optimization_level=1)
        pub  = (qc_t, hamiltonian)
        job  = estimator.run([pub])
        energy = job.result()[0].data.evs.item()
        energy_log.append(energy)
        iteration[0] += 1
        if iteration[0] % 5 == 0:
            print(f"  │   Step {iteration[0]:>3}: energy = {energy:.6f} Ha")
        return energy

    print(f"  │   Starting energy (warm): {energy_fn(warm_params):.6f} Ha")
    divider()

    t0 = time.time()
    result = minimize(
        energy_fn,
        warm_params,
        method="COBYLA",
        options={"maxiter": MAX_ITERATIONS, "rhobeg": 0.1}
    )
    sim_time = time.time() - t0

    final_energy = result.fun
    error        = abs(final_energy - EXACT_GROUND_STATE_ENERGY)

    divider()
    result_row("Ground state energy",  f"{final_energy:.6f}", " Ha", highlight=True)
    result_row("Known exact value",    f"{EXACT_GROUND_STATE_ENERGY:.6f}", " Ha")
    result_row("Error (with noise)",   f"{error:.6f}", " Ha")
    result_row("VQE iterations",       f"{iteration[0]}")
    result_row("Time",                 f"{sim_time:.3f}", " s")
    endsection()

    print(f"""
  ℹ️  Notice the error is LARGER than step ②.
     That's quantum noise in action — real chips make mistakes.
     Error mitigation techniques (ZNE, PEC) can reduce this.
     IBM's real hardware adds even more noise — but also gives
     true quantum parallelism that no simulator can fake.
    """)

    return final_energy, sim_time, energy_log


